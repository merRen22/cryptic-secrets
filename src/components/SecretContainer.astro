---
import '../styles/global.css';
import Button from './Button.astro';

interface Props {
  data?: string;
}

const { data } = Astro.props;
---

<div class="flex items-center justify-center min-h-screen">
  <div class="card bg-base-100 shadow-2xl w-full max-w-sm">
    <div class="card-body gap-6" style="padding: 3rem;">
      <h2 class="text-3xl font-bold">Enter Password</h2>
      <fieldset class="fieldset">
        <div class="join w-full gap-2">
          <input
            type="password"
            id="key"
            placeholder="Password"
            autocomplete="off"
            class="input input-bordered w-full"
          />
          <button id="toggle-password" class="btn border-base-300" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </button>
        </div>
      </fieldset>
      <Button class="btn btn-neutral w-full mt-4" id="decrypt">Decrypt</Button>
      <p id="error" class="text-error text-sm mt-2 hidden">Incorrect password</p>
    </div>
    <div class="card-body hidden" id="content-wrapper" style="padding: 3rem;">
      <div id="content" class="prose prose-invert max-w-none text-white"></div>
    </div>
  </div>
</div>

<script>
  import { marked } from 'marked';
  window.renderMarkdown = marked.parse.bind(marked);

  const toggleBtn = document.getElementById("toggle-password");
  const passwordInput = document.getElementById("key") as HTMLInputElement;

  toggleBtn?.addEventListener("click", () => {
    if (passwordInput.type === "password") {
      passwordInput.type = "text";
    } else {
      passwordInput.type = "password";
    }
  });
</script>