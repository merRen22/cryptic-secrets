---
import '../styles/global.css';

interface Props {
  data?: string;
}

const { data } = Astro.props;
---

<div class="max-w-[800px] w-full">
  {data && (
    <pre class="absolute inset-0 -z-10 opacity-10 overflow-hidden select-none pointer-events-none grayscale">{data}</pre>
  )}
  <div id="locked" class="border border-gray-200 rounded-lg p-8 text-center">
    <h1 class="text-2xl mb-4">Enter Password</h1>
    <input
      type="password"
      id="key"
      placeholder="Password"
      autocomplete="off"
      class="w-full px-4 py-3 text-base border border-gray-300 rounded mb-4"
    />
    <button id="decrypt" class="w-full px-4 py-3 text-base bg-black text-white border-none rounded cursor-pointer hover:bg-gray-800">
      Decrypt
    </button>
    <p id="error" class="text-red-600 mt-4">Incorrect password</p>
  </div>
  <pre id="content" class="whitespace-pre-wrap font-mono leading-relaxed hidden"></pre>
</div>