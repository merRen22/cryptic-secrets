---
import '../styles/global.css';
import Button from './Button.astro';

interface Props {
  data?: string;
}

const { data } = Astro.props;
---

<div class="max-w-[800px] w-full relative">
  {data && (
    <pre class="absolute inset-0 -z-10 flex items-center justify-center text-[4rem] font-mono text-white/40 select-none pointer-events-none leading-tight opacity-80 max-w-[50vw] overflow-hidden tracking-widest">{data}</pre>
  )}
  <div id="locked" class="border border-white/10 rounded-xl p-12 text-center">
    <h1 class="text-3xl font-semibold mb-6 text-white leading-tight">Enter Password</h1>
    <input
      type="password"
      id="key"
      placeholder="Password"
      autocomplete="off"
      class="w-full px-4 py-3 text-base bg-white/5 border border-white/10 rounded-lg mb-4 text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 transition-colors"
    />
    <Button id="decrypt">Decrypt</Button>
    <p id="error" class="text-red-500 mt-4">Incorrect password</p>
  </div>
  <pre id="content" class="whitespace-pre-wrap font-mono leading-relaxed hidden text-white"></pre>
</div>