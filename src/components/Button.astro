---
interface Props {
  id: string;
  variant?: 'primary' | 'secondary';
}

const { id, variant = 'primary' } = Astro.props;

const baseClasses = "btn";
const variants = {
  primary: "btn-primary",
  secondary: "btn-outline btn-primary"
};
---

<button {id} class:list={[baseClasses, variants[variant]]}>
  <slot />
</button>
